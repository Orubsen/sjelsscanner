# Google Gemini (free tier at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Deltakerlagring (navn, alder, e-post) bruker Netlify Blobs automatisk på deploy.
# Krever netlify dev (ikke kun vite) for lokal testing av /api/save-participant.

# Admin-side: https://ditt-domene.no/admin — sett et sterkt passord her:
PARTICIPANT_ADMIN_SECRET=bytt_til_et_langt_hemmelig_passord

# Legacy Anthropic (optional — app uses /api/gemini by default)
# ANTHROPIC_API_KEY=your_claude_api_key_here